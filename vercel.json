{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "regions": ["icn1"],
  "ignoreCommand": "exit 0",
  "crons": [
    { "path": "/api/cron/compute-signals", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/health-check", "schedule": "0 * * * *" }
  ]
}
