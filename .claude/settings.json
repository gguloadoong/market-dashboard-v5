{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/market-dashboard-v5/.claude/hooks/check-safety.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/market-dashboard-v5/.claude/hooks/check-gate-isolation.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/market-dashboard-v5/.claude/hooks/check-claudemd-size.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
