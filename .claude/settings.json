{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf ~)", "Bash(sudo *)",
      "Read(.env*)", "Read(**/credentials*)", "Read(**/*secret*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/market-dashboard-v5/.claude/hooks/check-gate-isolation.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/bong/market-dashboard-v5/.claude/hooks/check-claudemd-size.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
