# ─── 한국투자증권 Open API (필수 — 국장 실시간 시세·투자자 동향) ──
# VITE_ prefix 없음 = 클라이언트 번들 미포함, 서버 전용
# 발급: https://apiportal.koreainvestment.com
HANTOO_APP_KEY=your_hantoo_app_key
HANTOO_APP_SECRET=your_hantoo_app_secret

# ─── Upstash Redis (필수 — 전종목 스냅샷 캐시) ───────────────────
# 없으면 Redis 미연결 → Cron 저장 불가 → 전종목 0개 (서비스 불능)
# 발급: https://console.upstash.com → Redis 생성 → REST API 탭
KV_REST_API_URL=https://your-redis-name.upstash.io
KV_REST_API_TOKEN=your_upstash_token

# ─── Vercel Cron 인증 (필수 — Cron 보안) ────────────────────────
# CRON_SECRET 미설정 시 프로덕션 Cron 전체 차단 (500 반환)
# 발급: 임의 문자열 생성 (예: openssl rand -hex 32)
# Vercel 설정: Dashboard → Settings → Environment Variables
CRON_SECRET=your_cron_secret

# ─── Google Gemini (뉴스 AI 요약) ────────────────────────────────
# 발급: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# ─── 선택 사항 ────────────────────────────────────────────────────
# GROQ_API_KEY=your_groq_api_key
# KRX_API_KEY=your_krx_api_key
