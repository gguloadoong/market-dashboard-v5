{
  "name": "market-dashboard-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open false",
    "dev:verify": "bash -c 'PORT=${1:-5173}; for i in 1 2 3 4 5; do sleep 1; TITLE=$(curl -s http://localhost:$PORT/ 2>/dev/null | grep -o \"<title>[^<]*</title>\"); if [ -n \"$TITLE\" ]; then echo \"$TITLE\" | grep -q \"마켓레이더\" && echo \"✅ 마켓레이더 확인 (port $PORT)\" || echo \"❌ 잘못된 프로젝트: $TITLE (port $PORT)\"; exit 0; fi; done; echo \"⚠️ 서버 응답 없음 (port $PORT)\"' --",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "review:main": "node scripts/ai-pr-review.mjs --mode=local --base=origin/main",
    "review:base": "node scripts/ai-pr-review.mjs --mode=local",
    "test": "vitest run",
    "test:watch": "vitest",
    "architect": "bash scripts/run-architect.sh",
    "review:code": "bash scripts/run-code-reviewer.sh",
    "review:gate": "bash scripts/codex-review-gate.sh strict origin/main",
    "ship": "npm run lint && npm run test && npm run build && npm run review:gate",
    "pr": "bash scripts/create-pr.sh",
    "review:summary": "bash scripts/review-summary.sh",
    "deploy:check": "bash scripts/pre-deploy-consensus.sh",
    "setup:hooks": "git config core.hooksPath .githooks",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@coinbase/cds-web": "^8.62.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^10.18.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "javascript-obfuscator": "^5.4.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }
}
